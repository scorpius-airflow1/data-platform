# =============================================================================
# DATA PLATFORM — Airflow 3.2.0 + CeleryExecutor + Postgres externo
# .env.template — copia a .env y rellena los <PLACEHOLDERS>
# =============================================================================
# Convención:
#   [TODOS]        → master + workers
#   [SOLO MASTER]  → solo master usa
#   [SOLO WORKER]  → solo workers usan
#   [SOLO RABBIT]  → solo EC2 rabbitmq
# =============================================================================

# ----- CORE -----
PYTHONPATH=/opt/pipelines
AIRFLOW_UID=50000

# ----- WORKER IDENTITY (cambiar por nodo) -----
CELERY_HOSTNAME=worker-1                       # [SOLO WORKER] ← worker-2 / worker-3
QUEUES=default                                  # [SOLO WORKER]

# ----- RABBITMQ (broker) -----
RABBITMQ_USER=<RABBITMQ_USER>                   # [SOLO RABBIT]
RABBITMQ_PASS=<RABBITMQ_PASS>                   # [SOLO RABBIT]
RABBITMQ_VHOST=/                                # [SOLO RABBIT]

# ----- AIRFLOW CORE -----
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=<FERNET_KEY>          # mismo en master+workers
AIRFLOW__CORE__DAGS_FOLDER=/opt/pipelines/dags
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://airflow-apiserver:8080/execution/   # workers cambian a http://<MASTER_IP>:8080/execution/

# ----- DATABASE (Postgres externo) -----
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<USER>:<PASSWORD>@<DB_HOST>:5432/<DB_NAME>

# ----- CELERY -----
AIRFLOW__CELERY__BROKER_URL=amqp://<RABBITMQ_USER>:<RABBITMQ_PASS>@<RABBITMQ_HOST>:5672/
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql+psycopg2://<USER>:<PASSWORD>@<DB_HOST>:5432/<DB_NAME>

# ----- API SERVER (solo master) -----
AIRFLOW__API__BASE_URL=http://<PROXY_PUBLIC_IP>
AIRFLOW__API__INSTANCE_NAME=Airflow Data Platform
AIRFLOW__API__SECRET_KEY=<API_SECRET>

# ----- API AUTH JWT -----
AIRFLOW__API_AUTH__JWT_SECRET=<JWT_SECRET>     # mismo en master+workers

# ----- SCHEDULER / DAG PROCESSOR (solo master) -----
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=true
AIRFLOW__DAG_PROCESSOR__REFRESH_INTERVAL=300

# ----- LOGGING (S3 con IAM Role) -----
AIRFLOW__LOGGING__REMOTE_LOGGING=true
AIRFLOW__LOGGING__REMOTE_BASE_LOG_FOLDER=s3://<BUCKET>/logs
AIRFLOW__LOGGING__REMOTE_LOG_CONN_ID=aws_default
AIRFLOW__LOGGING__ENCRYPT_S3_LOGS=false

# ----- INIT (solo master, primer arranque) -----
_AIRFLOW_DB_MIGRATE=true
_AIRFLOW_WWW_USER_CREATE=true
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=<ADMIN_PASSWORD>

# ----- EXTRA -----
EXTRA_REQUIREMENTS=